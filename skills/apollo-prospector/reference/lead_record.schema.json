{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lead Record",
  "description": "Individual lead record from Apollo or other sources",
  "type": "object",
  "required": ["lead_id", "first_name", "last_name", "title", "company_name", "email"],
  "properties": {
    "lead_id": {
      "type": "string",
      "description": "Unique identifier (Apollo ID or generated UUID)"
    },
    "first_name": { "type": "string" },
    "last_name": { "type": "string" },
    "title": { "type": "string" },
    "seniority": { "type": "string" },
    "department": { "type": "string" },
    "company_name": { "type": "string" },
    "company_domain": { "type": "string" },
    "company_industry": { "type": "string" },
    "company_size": {
      "type": "string",
      "description": "Employee count range"
    },
    "company_revenue": { "type": "string" },
    "company_location": { "type": "string" },
    "company_linkedin_url": { "type": "string" },
    "linkedin_url": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "email_status": {
      "type": "string",
      "enum": ["verified", "guessed", "unavailable"]
    },
    "phone": { "type": "string" },
    "technologies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recent_activity": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "detail": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "string",
      "enum": ["apollo", "manual", "enriched"],
      "default": "apollo"
    },
    "pulled_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
